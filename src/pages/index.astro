      <div class="flex items-center gap-6">
        <a href="https://notbadlah.com" style="font-size:0.8rem;color:rgba(255,255,255,0.4);text-decoration:none;">RintiZ (Part-time)</a>
        <a href="https://nextgenmillionaire-plus.notbadlah.com" style="font-size:0.8rem;color:rgba(255,255,255,0.4);text-decoration:none;">NGM+ (Experienced)</a>
        <a href="https://shazemeen.com" style="font-size:0.8rem;color:rgba(255,255,255,0.4);text-decoration:none;">About Charles</a>
