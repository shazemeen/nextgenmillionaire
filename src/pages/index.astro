<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Hero entrance
  gsap.from('#hero-left > *', {
    opacity: 0, y: 30, stagger: 0.1, duration: 0.8, ease: 'power3.out', delay: 0.15
  });
  gsap.from('#hero-right', {
    opacity: 0, x: 30, duration: 0.9, ease: 'power3.out', delay: 0.4
  });

  // Scroll fade-ups
  document.querySelectorAll('.fade-up').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 28 },
      {
        opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' }
      }
    );
  });

  // FAQ
  document.querySelectorAll('.faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as SVGElement;
      const isOpen = answer.style.display === 'block';
      document.querySelectorAll('.faq-answer').forEach((a: Element) => { (a as HTMLElement).style.display = 'none'; });
      document.querySelectorAll('.faq-icon').forEach((i: Element) => { (i as SVGElement).style.transform = 'rotate(0deg)'; });
      if (!isOpen) { answer.style.display = 'block'; icon.style.transform = 'rotate(180deg)'; }
    });
  });

  // Apply form
  const form = document.getElementById('apply-form') as HTMLFormElement;
  const formMsg = document.getElementById('form-msg') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      if (res.ok) {
        form.reset();
        formMsg.style.display = 'block';
        formMsg.style.background = '#F0FFF4';
        formMsg.style.border = '1px solid #86EFAC';
        formMsg.style.color = '#166534';
        formMsg.textContent = "Done! Charles will reach out within 24 hours — expect a WhatsApp or call.";
        submitBtn.textContent = 'Submitted ✓';
        submitBtn.style.background = '#166534';
      } else { throw new Error(); }
    } catch {
      formMsg.style.display = 'block';
      formMsg.style.background = '#FFF5F5';
      formMsg.style.border = '1px solid #FCA5A5';
      formMsg.style.color = '#991B1B';
      formMsg.textContent = 'Something went wrong. Try again or WhatsApp Charles directly.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Expression of Interest';
    }
  });
</script>
