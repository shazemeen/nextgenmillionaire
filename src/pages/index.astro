              onfocus="this.style.borderColor='#D4AF37';this.style.background='#FFFDF5'" onblur="this.style.borderColor='#e0e0e0';this.style.background='#F8F8F6'" />
          </div>

          <div>
            <label style="display:block;font-size:0.72rem;font-weight:700;color:#888;margin-bottom:6px;letter-spacing:0.05em;text-transform:uppercase;">Current Job Title *</label>
            <input type="text" name="job_title" required placeholder="e.g. Senior Executive, Business Owner, Teacher"
              style="width:100%;padding:12px 14px;background:#F8F8F6;border:1.5px solid #e0e0e0;border-radius:10px;color:#111;font-size:0.9rem;outline:none;transition:border-color 0.2s,background 0.2s;"
              onfocus="this.style.borderColor='#D4AF37';this.style.background='#FFFDF5'" onblur="this.style.borderColor='#e0e0e0';this.style.background='#F8F8F6'" />
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
            <div>
              <label style="display:block;font-size:0.72rem;font-weight:700;color:#888;margin-bottom:6px;letter-spacing:0.05em;text-transform:uppercase;">Monthly Income *</label>
              <select name="monthly_income" required
                style="width:100%;padding:12px 14px;background:#F8F8F6;border:1.5px solid #e0e0e0;border-radius:10px;color:#111;font-size:0.9rem;outline:none;transition:border-color 0.2s;appearance:none;cursor:pointer;"
