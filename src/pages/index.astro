<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Nav background on scroll
  const nav = document.getElementById('nav');
  ScrollTrigger.create({
    start: 80,
    onEnter: () => {
      if (nav) {
        nav.style.background = 'rgba(12,27,51,0.97)';
        nav.style.backdropFilter = 'blur(12px)';
        nav.style.boxShadow = '0 1px 0 rgba(255,255,255,0.06)';
      }
    },
    onLeaveBack: () => {
      if (nav) {
        nav.style.background = 'transparent';
        nav.style.backdropFilter = '';
        nav.style.boxShadow = '';
      }
    }
  });

  // Hero entrance
  gsap.from('#hero-left > *', {
    opacity: 0, y: 40, stagger: 0.12, duration: 0.9, ease: 'power3.out', delay: 0.2
  });
  gsap.from('#hero-right', {
    opacity: 0, x: 40, duration: 1, ease: 'power3.out', delay: 0.5
  });

  // Scroll fade-ups
  document.querySelectorAll('.fade-up').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 36 },
      {
        opacity: 1, y: 0, duration: 0.75, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
      }
    );
  });

  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as SVGElement;
      const isOpen = answer.style.display === 'block';
      // Close all
      document.querySelectorAll('.faq-answer').forEach((a: Element) => { (a as HTMLElement).style.display = 'none'; });
      document.querySelectorAll('.faq-icon').forEach((i: Element) => { (i as SVGElement).style.transform = 'rotate(0deg)'; });
      // Toggle current
      if (!isOpen) {
        answer.style.display = 'block';
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });

  // Apply form
  const form = document.getElementById('apply-form') as HTMLFormElement;
  const formMsg = document.getElementById('form-msg') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (res.ok) {
        form.reset();
        formMsg.style.display = 'block';
        formMsg.style.background = 'rgba(212,175,55,0.1)';
        formMsg.style.border = '1px solid rgba(212,175,55,0.3)';
        formMsg.style.color = '#D4AF37';
        formMsg.textContent = "Done! Charles will reach out within 24 hours. Expect a WhatsApp or call.";
        submitBtn.textContent = 'Submitted ✓';
        submitBtn.style.background = 'rgba(212,175,55,0.3)';
      } else {
        throw new Error('Server error');
      }
    } catch {
      formMsg.style.display = 'block';
      formMsg.style.background = 'rgba(200,16,46,0.1)';
      formMsg.style.border = '1px solid rgba(200,16,46,0.3)';
      formMsg.style.color = '#ff6b6b';
      formMsg.textContent = 'Something went wrong. Try again or WhatsApp Charles directly.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Expression of Interest';
    }
  });
</script>
